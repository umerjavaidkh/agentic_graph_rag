# ── Required ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Neo4j (only when running API locally, NOT in Docker) ─────────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password123
# Bundled Docker Neo4j uses bolt://neo4j:7687 automatically — do not set NEO4J_URI in .env.

# ── Docker ports (default avoids clash with local Neo4j on 7474/7687) ────
# NEO4J_HTTP_PORT=17474
# NEO4J_BOLT_PORT=17687
# APP_PORT=8000

# ── Use existing Neo4j on your machine instead of bundled container ───────
# NEO4J_URI=bolt://host.docker.internal:7687
# NEO4J_PASSWORD=your-local-neo4j-password
# Then: docker compose -f docker-compose.yml -f docker-compose.external-neo4j.yml up --build --scale neo4j=0

# ── LLM / embeddings ─────────────────────────────────────────────────────
# CHAT_MODEL=gpt-4o-mini
# STRUCTURED_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small
# STRUCTURED_ALWAYS_MULTISTEP_PLAN=false  # true = extra LLM plan call on every structured query
# LLM max_tokens (per pipeline stage)
# STRUCTURED_SYNTHESIS_MAX_TOKENS=600
# STRUCTURED_TEXT2CYPHER_MAX_TOKENS=500
# STRUCTURED_TEXT2CYPHER_LONG_MAX_TOKENS=900
# STRUCTURED_PLAN_MAX_TOKENS=           # fixed override; else uses SMALL/MEDIUM/LARGE tiers
# STRUCTURED_PLAN_TOKENS_SMALL=900
# STRUCTURED_PLAN_TOKENS_MEDIUM=1600
# STRUCTURED_PLAN_TOKENS_LARGE=2200
# DOCUMENT_SYNTHESIS_MAX_TOKENS=600
# DOCUMENT_SYNTHESIS_LONG_MAX_TOKENS=1400
# VISION_LLM_MAX_TOKENS=2000
# AXIS2_NER_MAX_TOKENS=200
# AXIS2_RELATION_MAX_TOKENS=150
# ROUTE_MAX_TOKENS=                  # fixed override; else estimated from question length
# ROUTE_MAX_TOKENS_BASE=128
# ROUTE_MAX_TOKENS_MIN=64
# ROUTE_MAX_TOKENS_CAP=1024

# ── Lightweight PDF parser ──────────────────────────────────────────────
# PDF_PARSER_BACKEND=light
# PDF_ENABLE_PDFPLUMBER=true
# PDF_LOW_TEXT_CHARS=120
# PDF_PLUMBER_PAGE_TIMEOUT_SEC=25
# PDF_ENABLE_OCR=false
# PDF_OCR_BACKEND=none

# ── Page vision (costs OpenAI credits) ───────────────────────────────────
# Stores diagram/table descriptions on Page.visual_content (text in Neo4j, not JPEG files).
# ENABLE_PAGE_VISION=false

# ── Document versioning (logical doc + revision snapshots) ───────────────
# DOC_SKIP_DUPLICATE_HASH=true          # skip ingest when ACTIVE revision has same SHA-256
# DOC_VERSION_RETAIN_METADATA=true      # keep EXPIRED DocRevision nodes for audit
