# ── Required ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Neo4j (only when running API locally, NOT in Docker) ─────────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password123
# Bundled Docker Neo4j uses bolt://neo4j:7687 automatically — do not set NEO4J_URI in .env.

# ── Docker ports (default avoids clash with local Neo4j on 7474/7687) ────
# NEO4J_HTTP_PORT=17474
# NEO4J_BOLT_PORT=17687
# APP_PORT=8000

# ── Use existing Neo4j on your machine instead of bundled container ───────
# NEO4J_URI=bolt://host.docker.internal:7687
# NEO4J_PASSWORD=your-local-neo4j-password
# Then: docker compose -f docker-compose.yml -f docker-compose.external-neo4j.yml up --build --scale neo4j=0

# ── LLM / embeddings ─────────────────────────────────────────────────────
# CHAT_MODEL=gpt-4o-mini
# STRUCTURED_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small

# ── Page vision (costs OpenAI credits) ───────────────────────────────────
# ENABLE_PAGE_VISION=false

# ── PDF ingest: slim image has ENABLE_PDF_INGEST=false. Full image (~10 GB):
# docker compose -f docker-compose.yml -f docker-compose.full.yml up --build
