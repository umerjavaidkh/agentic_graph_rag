# Copy to .env and fill in values:
#   cp .env.example .env
#
# Docker: docker compose up --build
#   - NEO4J_URI is forced to bolt://neo4j:7687 inside containers (do not set localhost in .env).
#   - REDIS_URL is set to redis://redis:6379/0 in docker-compose.yml for app/worker.
#
# Active models after start: GET http://localhost:8000/config/models

# ── Required ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Authentication (OIDC / JWT — Google by default) ─────────────────────
# AUTH_ENABLED=false keeps eval/dev body user_id+role (no login).
# AUTH_ENABLED=true + GOOGLE_CLIENT_ID → Sign in with Google in chat UI.
AUTH_ENABLED=false
AUTH_PROVIDER=google
GOOGLE_CLIENT_ID=
# Corporate IdP (AUTH_PROVIDER=oidc):
# OIDC_ISSUER=https://login.yourorg.com
# OIDC_AUDIENCE=rag-api
# OIDC_JWKS_URL=
# Chat role for new Google/OIDC users (email map overrides). JIT re-syncs to Neo4j each login.
AUTH_DEFAULT_ROLE=compliance_officer
# Ingestion + /admin/* require admin; map operator emails here (comma-separated):
# AUTH_EMAIL_ROLE_MAP=you@company.com=admin
# AUTH_CLAIM_ROLE_MAP={"RAG-Staff":"regular_office","RAG-Admin":"admin"}
# AUTH_TRUSTED_EMAIL_DOMAINS=company.com
# AUTH_DOMAIN_DEFAULT_ROLE=regular_office
AUTH_JIT_PROVISION=true
# true = sidebar user_id/role when unsigned in; false = Google/OIDC only (production).
AUTH_ALLOW_BODY_FALLBACK=true

# ── Neo4j ────────────────────────────────────────────────────────────────
# Bundled Docker: credentials below; URI is set by docker-compose (bolt://neo4j:7687).
# Local API (no Docker): uncomment NEO4J_URI.
# NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# External Neo4j instead of bundled container:
# NEO4J_URI=bolt://host.docker.internal:7687
# NEO4J_PASSWORD=your-local-neo4j-password
# docker compose -f docker-compose.yml -f docker-compose.external-neo4j.yml up --build --scale neo4j=0

# ── Docker host ports (avoid clash with local Neo4j on 7474/7687) ─────────
NEO4J_HTTP_PORT=17474
NEO4J_BOLT_PORT=17687
APP_PORT=8000
REDIS_PORT=6379

# ── LLM / embeddings (restart app after changes) ─────────────────────────
MODEL_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
STRUCTURED_MODEL=gpt-4.1-mini
ROUTING_MODEL=gpt-4o-mini
AXIS2_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=gpt-4o-mini

# Structured routing / answers
STRUCTURED_ALWAYS_MULTISTEP_PLAN=false
STRUCTURED_EMPTY_MULTISTEP_FALLBACK=true
STRUCTURED_FAST_ANSWER=false
FAST_ROUTE_QUERIES=true
QUERY_STREAM_ENABLED=true
STRUCTURED_CYPHER_MAX_ATTEMPTS=2
STRUCTURED_CYPHER_SQL_LLM_RETRIES=1
STRUCTURED_EMPTY_RESULT_LLM_RETRIES=1
STRUCTURED_MULTISTEP_STEP_ATTEMPTS=2

# LLM max_tokens (per pipeline stage)
DOCUMENT_SYNTHESIS_MAX_TOKENS=500
DOCUMENT_SYNTHESIS_LONG_MAX_TOKENS=1200
STRUCTURED_SYNTHESIS_MAX_TOKENS=800
STRUCTURED_SYNTHESIS_LONG_MAX_TOKENS=4096
STRUCTURED_TEXT2CYPHER_MAX_TOKENS=600
STRUCTURED_TEXT2CYPHER_LONG_MAX_TOKENS=1200
STRUCTURED_TEXT2CYPHER_LONG_QUERY_CHARS=180
STRUCTURED_PLAN_MAX_TOKENS=
STRUCTURED_PLAN_TOKENS_SMALL=900
STRUCTURED_PLAN_TOKENS_MEDIUM=1600
STRUCTURED_PLAN_TOKENS_LARGE=2400
STRUCTURED_PLAN_QUERY_MEDIUM_CHARS=160
STRUCTURED_PLAN_QUERY_LARGE_CHARS=260
STRUCTURED_PLAN_SCHEMA_MEDIUM_CHARS=3500
STRUCTURED_PLAN_SCHEMA_LARGE_CHARS=6000
ROUTE_MAX_TOKENS=
ROUTE_MAX_TOKENS_BASE=128
ROUTE_MAX_TOKENS_MIN=64
ROUTE_MAX_TOKENS_CAP=512
AXIS2_NER_MAX_TOKENS=150
AXIS2_RELATION_MAX_TOKENS=120
VISION_LLM_MAX_TOKENS=2000

# ── Retrieval ────────────────────────────────────────────────────────────
RETRIEVAL_CANDIDATE_POOL=30
RETRIEVAL_FINAL_LIMIT=8
RETRIEVAL_MIN_RERANK_SCORE=0.12

# Retrieval feedback — persist pipeline telemetry for offline learning.
# Production: Redis Stream + aggregates (requires REDIS_URL).
# Dev without Redis: JSONL under data/feedback/.
RETRIEVAL_FEEDBACK_ENABLED=true
# When true, apply labeled pass/fail hints to structured multistep vs text2cypher and document hybrid mode.
RETRIEVAL_FEEDBACK_ROUTING=false
RETRIEVAL_FEEDBACK_STORE_QUESTION=false
# optional tuning:
# RETRIEVAL_FEEDBACK_STREAM_MAXLEN=100000
# RETRIEVAL_FEEDBACK_AGG_TTL_DAYS=90
# RETRIEVAL_FEEDBACK_DIR=data/feedback
# RETRIEVAL_FEEDBACK_REDIS_STREAM=rag:feedback:events
# RETRIEVAL_FEEDBACK_REQ_TTL_SEC=604800
# RETRIEVAL_FEEDBACK_MIN_SAMPLES=30
# RETRIEVAL_FEEDBACK_MIN_MARGIN=0.15

# ── Neo4j / ingest security & behaviour ────────────────────────────────────
AUTO_LOAD_TO_NEO4J=true
ALLOW_DB_RESET=false
ALLOW_CYPHER_INGEST=true
CYPHER_INGEST_SKIP_GENAI=true
CLEANUP_TMP_INGEST=true
STORE_INGESTION_ARTIFACTS=false

# ── Document versioning ────────────────────────────────────────────────────
DOC_SKIP_DUPLICATE_HASH=true
DOC_VERSION_RETAIN_METADATA=true

# ── Lightweight PDF parser ─────────────────────────────────────────────────
PDF_PARSER_BACKEND=light
PDF_ENABLE_PDFPLUMBER=true
PDF_LOW_TEXT_CHARS=120
PDF_PLUMBER_PAGE_TIMEOUT_SEC=25
PDF_ENABLE_OCR=false
PDF_OCR_BACKEND=none

# ── Page vision (costs OpenAI credits) ───────────────────────────────────
# Stores diagram/table descriptions on Page.visual_content (text in Neo4j).
ENABLE_PAGE_VISION=false
VISION_DPI=120
VISION_IMAGE_DETAIL=low
VISION_MAX_PAGES_PER_DOC=25
VISION_SELECTIVE=true
VISION_MIN_TEXT_CHARS=350

# ── PDF page / region images (ingest) ─────────────────────────────────────
PAGE_IMAGE_SELECTIVE=false
PAGE_IMAGE_MAX_PAGES=0
ENABLE_PAGE_IMAGES=true
ENABLE_REGION_IMAGES=true

# ── Scalable ingestion (Redis + RQ workers) ───────────────────────────────
# Unset REDIS_URL = in-process BackgroundTasks (single-process dev).
# Docker compose also sets this for app and worker.
REDIS_URL=redis://redis:6379/0
INGEST_QUEUE_NAME=ingest
INGEST_WORKER_CONCURRENCY=2
AXIS2_NER_CONCURRENCY=8
AXIS2_LLM_PAIR_CONCURRENCY=6
AXIS2_MAX_LLM_PAIRS=300
NEO4J_WRITE_BATCH=2000

# ── Demo bootstrap (docker-compose may override) ─────────────────────────
LOAD_NORTHWIND_DEMO=true
ENABLE_PDF_INGEST=true
